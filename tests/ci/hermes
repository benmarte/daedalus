#!/usr/bin/env python3
"""Lightweight ``hermes`` CLI stub for the Daedalus plugin-lifecycle CI.

Hermes is a private tool (not on PyPI, no public installer), so CI cannot run the
real binary. Every install-path regression issue #88 guards against — #75
(missing deps), #79 (per-profile cron dedup), #80 (cron lost after ``hermes
update``) — lives in the plugin's *own* scripts, not in Hermes. This stub records
just enough cron / profile / plugin / kanban state under an isolated
``$HERMES_HOME`` for the *real* ``postinstall.py``, ``provision_roster.sh``,
``register()`` and ``uninstall.sh`` to run end-to-end and be asserted against.

It is NOT a Hermes reimplementation: it stores state as JSON/dirs and emits the
exact stdout the calling scripts parse. Unknown subcommands succeed (exit 0) so a
new ``hermes`` call in a script never breaks CI silently — every invocation is
appended to ``$HERMES_HOME/stub-calls.log`` for debugging.

Implemented surface (the union of what the lifecycle scripts invoke):
    cron list --all
    cron create <schedule> --name <n> --script <s> --no-agent [--deliver <t>] [--repeat <n>]
    cron delete|remove <name>
    profile list
    profile create <name> --clone --description <desc>
    profile delete <name> -y
    plugins install <repo> --enable | plugins disable|remove <name>
    kanban boards list | boards rm <slug> --delete | boards add <slug>
    send ... | gateway ...            (no-op, exit 0)
"""

from __future__ import annotations

import hashlib
import json
import os
import shutil
import sys
from pathlib import Path

HERMES_HOME = Path(os.environ.get("HERMES_HOME") or os.path.expanduser("~/.hermes"))
CRON = HERMES_HOME / "cron" / "jobs.json"
BOARDS = HERMES_HOME / "kanban" / "boards.json"
PROFILES = HERMES_HOME / "profiles"
PLUGINS = HERMES_HOME / "plugins"

# Flags that consume the following token as their value (everything else with a
# leading dash is a boolean flag; bare tokens are positionals).
VALUE_FLAGS = {"--name", "--script", "--schedule", "--deliver", "--repeat", "--description"}


def _log(argv: list[str]) -> None:
    try:
        HERMES_HOME.mkdir(parents=True, exist_ok=True)
        with open(HERMES_HOME / "stub-calls.log", "a") as fh:
            fh.write("hermes " + " ".join(argv) + "\n")
    except OSError:
        pass


def _load(path: Path, default):
    try:
        return json.loads(path.read_text())
    except (OSError, ValueError):
        return default


def _save(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2))


def _parse(args: list[str]):
    pos: list[str] = []
    opts: dict[str, object] = {}
    i = 0
    while i < len(args):
        a = args[i]
        if a in VALUE_FLAGS:
            opts[a] = args[i + 1] if i + 1 < len(args) else ""
            i += 2
        elif a.startswith("-"):
            opts[a] = True
            i += 1
        else:
            pos.append(a)
            i += 1
    return pos, opts


def cmd_cron(pos, opts) -> int:
    action = pos[0] if pos else ""
    jobs = _load(CRON, [])
    if action == "list":
        # Block format parsed by uninstall.sh (header `<hex> [status]` + Name:/Script:)
        # and __init__.py (`^\s*Name:\s+(.+)$`).
        for job in jobs:
            jid = hashlib.sha1(job["name"].encode()).hexdigest()[:12]
            print(f"  {jid} [{job.get('status', 'active')}]")
            print(f"    Name: {job['name']}")
            print(f"    Script: {job.get('script', '')}")
            print(f"    Schedule: {job.get('schedule', '')}")
        return 0
    if action == "create":
        schedule = pos[1] if len(pos) > 1 else ""
        name = opts.get("--name") or ""
        if name and not any(j["name"] == name for j in jobs):
            jobs.append({
                "name": name,
                "script": opts.get("--script", ""),
                "schedule": schedule,
                "status": "active",
            })
            _save(CRON, jobs)
        print(f"created cron {name}")
        return 0
    if action in ("delete", "remove"):
        name = pos[1] if len(pos) > 1 else (opts.get("--name") or "")
        remaining = [j for j in jobs if j["name"] != name]
        _save(CRON, remaining)
        if len(remaining) == len(jobs):
            print(f"no such cron: {name}", file=sys.stderr)
            return 1
        print(f"removed cron {name}")
        return 0
    return 0


def cmd_profile(pos, opts) -> int:
    action = pos[0] if pos else ""
    PROFILES.mkdir(parents=True, exist_ok=True)
    if action == "list":
        names = []
        if (PROFILES / "default").is_dir() or (HERMES_HOME / "config.yaml").is_file():
            names.append("default")
        for child in sorted(PROFILES.iterdir()):
            if child.is_dir() and child.name != "default":
                names.append(child.name)
        for name in names:
            print(name)
        return 0
    if action == "create":
        name = pos[1] if len(pos) > 1 else ""
        if not name:
            return 0
        pdir = PROFILES / name
        pdir.mkdir(parents=True, exist_ok=True)
        # --clone copies config from the default/global profile (model + provider keys).
        src = PROFILES / "default" / "config.yaml"
        if not src.is_file():
            src = HERMES_HOME / "config.yaml"
        (pdir / "config.yaml").write_text(src.read_text() if src.is_file() else "model: stub\n")
        (pdir / "auth.json").write_text("{}")
        (pdir / ".env").write_text("")
        (pdir / "SOUL.md").write_text("# stub soul\n")
        return 0
    if action == "delete":
        name = pos[1] if len(pos) > 1 else ""
        pdir = PROFILES / name
        if pdir.is_dir():
            shutil.rmtree(pdir)
            print(f"deleted profile {name}")
            return 0
        print(f"no such profile: {name}", file=sys.stderr)
        return 1
    return 0


def cmd_plugins(pos, opts) -> int:
    action = pos[0] if pos else ""
    if action == "install":
        repo = pos[1] if len(pos) > 1 else ""
        base = repo.split("/")[-1] if repo else "plugin"
        (PLUGINS / base / "skills").mkdir(parents=True, exist_ok=True)
        print(f"installed {repo}")
        return 0
    if action in ("remove", "uninstall"):
        name = pos[1] if len(pos) > 1 else ""
        pdir = PLUGINS / name
        if pdir.is_dir():
            shutil.rmtree(pdir)
        print(f"removed {name}")
        return 0
    if action in ("disable", "enable"):
        print(f"{action}d {pos[1] if len(pos) > 1 else ''}")
        return 0
    return 0


def cmd_kanban(pos, opts) -> int:
    if len(pos) >= 2 and pos[0] == "boards":
        sub = pos[1]
        boards = _load(BOARDS, [{"slug": "default", "name": "Default"}])
        if sub == "list":
            print("SLUG            NAME")  # NR==1 header, skipped by uninstall's awk
            for board in boards:
                print(f"{board['slug']:<15} {board.get('name', board['slug'])}")
            return 0
        if sub in ("rm", "remove"):
            slug = pos[2] if len(pos) > 2 else ""
            _save(BOARDS, [b for b in boards if b["slug"] != slug])
            print(f"removed board {slug}")
            return 0
        if sub in ("add", "create"):
            slug = pos[2] if len(pos) > 2 else ""
            if slug and not any(b["slug"] == slug for b in boards):
                boards.append({"slug": slug, "name": slug})
                _save(BOARDS, boards)
            print(f"added board {slug}")
            return 0
    return 0


def main() -> int:
    argv = sys.argv[1:]
    _log(argv)
    if not argv:
        return 0
    group, rest = argv[0], argv[1:]
    pos, opts = _parse(rest)
    handler = {
        "cron": cmd_cron,
        "profile": cmd_profile,
        "plugins": cmd_plugins,
        "kanban": cmd_kanban,
    }.get(group)
    if handler:
        return handler(pos, opts)
    # send / gateway / setup / anything else — succeed quietly (already logged).
    return 0


if __name__ == "__main__":
    sys.exit(main())
